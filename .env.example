# Lon Docker Compose — 환경변수 (선택)
# `cp .env.example .env` 후 값 변경

# MariaDB
MARIADB_PORT=3306
MARIADB_ROOT_PASSWORD=rootpw_change_me
MARIADB_PASSWORD=CHANGE_ME_LON_2026

# MongoDB
MONGO_PORT=27017
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpw_change_me
MONGO_PASSWORD=CHANGE_ME_LON_2026

# API
API_PORT=8089
JWT_SECRET=dev-only-not-for-prod-32chars-please-change
# openssl rand -base64 32  → 32바이트 base64
AES_MASTER_KEY_B64=

# Web (nginx)
WEB_PORT=8080
